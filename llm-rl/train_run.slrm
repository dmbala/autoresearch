#!/bin/bash
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task=8
#SBATCH --mem=128GB
#SBATCH --gres=gpu:2
#SBATCH --partition=kempner_dev
#SBATCH --account=kempner_dev
#SBATCH --time=12:00:00
#SBATCH --signal=B:USR1@120
#SBATCH --job-name=llm-rl-auto
#SBATCH --output=logs/%N.%x.%j.out
#SBATCH --error=logs/%N.%x.%j.err

cd /n/netscratch/kempner_dev/Lab/bdesinghu/Agent/prep-autoresearch/Test2/autoresearch/llm-rl
mkdir -p logs

resubmit() {
  echo "Caught timeout signal — resubmitting job"
  sbatch "$0"
  exit 0
}
trap resubmit USR1

claude --allowedTools "Bash,Read,Edit,Write,Glob,Grep" \
  -p "follow program.md and run the training experiment loop" &
wait

sbatch --begin=now+1hour $0  # resubmit this script when done
