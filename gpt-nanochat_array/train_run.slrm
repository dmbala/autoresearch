#!/bin/bash
#SBATCH --nodes=1
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task=4
#SBATCH --mem=16GB
#SBATCH --partition=kempner_eng
#SBATCH --account=kempner_dev
#SBATCH --time=72:00:00
#SBATCH --job-name=nanochat-agent
#SBATCH --output=logs/%N.%x.%j.out
#SBATCH --error=logs/%N.%x.%j.err

cd /n/netscratch/kempner_dev/Lab/bdesinghu/Agent/prep-autoresearch/Test2/autoresearch/gpt-nanochat_array
mkdir -p logs configs results

claude --allowedTools "Bash,Read,Edit,Write,Glob,Grep" \
  -p "follow program.md and run the experiment loop"

sbatch --begin=now+1hour $0  # resubmit this script when done
